# =============================================================
# Y2TB bot environment config example
#
# How to use:
# 1) Copy this file to config/config.env
# 2) Edit values below
# 3) Restart bot
#
# Value types:
# - boolean: true/false
# - number: 5, 10, ...
# - array: JSON format, e.g. ["10001","10002"]
# =============================================================

# -----------------------------
# Main config
# Prefix: Y2TB_CFG_
# -----------------------------

# Bot display name.
Y2TB_CFG_BOT_INFO_BOTNAME=Y2TBbot

# Bot language code. Must match available language files.
# Common values: en_US, vi_VN
Y2TB_CFG_BOT_INFO_LANG=en_US

# Facebook login email (leave empty if using fbstate).
Y2TB_CFG_FACEBOOK_FBEMAIL=

# Facebook login password (leave empty if using fbstate).
Y2TB_CFG_FACEBOOK_FBPASSWORD=

# Command prefix, for example: /, !, .
Y2TB_CFG_FACEBOOK_PREFIX=/

# Admin UID list (JSON array).
# Example: ["100042415119261","1000123456789"]
Y2TB_CFG_FACEBOOK_ADMIN=[]

# Auto mark incoming messages as read.
Y2TB_CFG_FACEBOOK_AUTOMARKREAD=true

# If true, bot can respond to its own messages.
Y2TB_CFG_FACEBOOK_SELFLISTEN=false

# UID mode option (keep default unless you know this flow).
Y2TB_CFG_FACEBOOK_UIDMODE=disabled

# Blacklist thread/user IDs (JSON array).
Y2TB_CFG_FACEBOOK_BLACKLIST=[]

# Whitelist thread/user IDs (JSON array).
# If not empty, only IDs in this list can use bot commands.
Y2TB_CFG_FACEBOOK_WHITELIST=[]

# -----------------------------
# Core config
# Prefix: Y2TB_CORE_
# -----------------------------

# Data autosave interval in seconds.
Y2TB_CORE_MAIN_BOT_DATASAVETIME=5

# Developer mode:
# - true: prioritize local/dev behavior
# - false: normal mode
Y2TB_CORE_MAIN_BOT_DEVELOPMODE=false

# Enable normal logs.
Y2TB_CORE_MAIN_BOT_TOGGLELOG=true

# Enable debug logs.
Y2TB_CORE_MAIN_BOT_TOGGLEDEBUG=false

# Facebook API log level.
# Common values: error, warn, info
Y2TB_CORE_FACEBOOK_LOGLEVEL=error

# Browser user agent string for login/session behavior.
Y2TB_CORE_FACEBOOK_USERAGENT=

# Listen to Facebook event messages (member join/leave, etc.).
Y2TB_CORE_FACEBOOK_LISTENEVENTS=true

# Update presence status.
Y2TB_CORE_FACEBOOK_UPDATEPRESENCE=false

# Auto-save latest FB state (cookies) every N minutes.
# Set <= 0 to fallback to default (30 minutes).
Y2TB_CORE_FACEBOOK_FBSTATEAUTOSAVEMINUTES=30

# Enable E2EE bridge support in fca-unofficial.
Y2TB_CORE_FACEBOOK_ENABLEE2EE=false

# Auto-connect E2EE bridge after login when enabled.
Y2TB_CORE_FACEBOOK_E2EEAUTOCONNECT=true

# Device store path used by E2EE (required for connectE2EE).
Y2TB_CORE_FACEBOOK_E2EEDEVICESTOREPATH=config/device-store.json

# Session store path used by E2EE (optional).
Y2TB_CORE_FACEBOOK_E2EESESSIONSTOREPATH=config/e2ee_session.json

# Legacy device path (fallback for older configs).
Y2TB_CORE_FACEBOOK_E2EEDEVICEPATH=config/e2ee_device.json
